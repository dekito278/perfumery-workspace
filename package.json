{
  "name": "monorepo",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": "20.19.x || 22.x || >=24"
  },
  "scripts": {
    "dev": "npm run dev:web",
    "dev:legacy": "concurrently --kill-others --raw \"npm run dev --prefix apps/web\" \"npm run dev --prefix apps/api\" \"npm run dev --prefix apps/pocketbase\"",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:web:3002": "npm run dev --prefix apps/web -- --host 127.0.0.1 --port 3002 --strictPort",
    "build": "npm run build:web",
    "build:web": "npm run build --prefix apps/web",
    "start": "npm run start --prefix apps/web",
    "start:legacy": "concurrently --kill-others --raw \"npm run start --prefix apps/api\" \"npm run start --prefix apps/pocketbase\"",
    "lint": "npm run lint:web",
    "lint:web": "npm run lint --prefix apps/web",
    "lint:warn": "npm run lint:warn --prefix apps/web",
    "lint:legacy": "npm run lint --prefix apps/api",
    "browser:smoke": "npm --prefix apps/web run browser:smoke --",
    "e2e:production-flow": "npm --prefix apps/web run e2e:production-flow --"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "workspaces": [
    "apps/web"
  ],
  "dependencies": {
    "ai": "^6.0.0",
    "zod": "^4.3.6"
  }
}
